# BiteStreak – Vite local environment
# File: frontend\.env.local
#
# Vite reads this file automatically during `npm run dev`.
# All variables MUST start with VITE_ to be exposed to the browser.
#
# The vite.config.js proxy forwards /api/* to this URL,
# so you can also leave this as-is and rely on the proxy.

VITE_API_URL=https://freshbites-backend-c6vd.onrender.com
